arch=('any')
url="https://www.peter-wiegel.de/"
license=('OFL')
depends=('fontconfig')
makedepends=('fontconfig')
optdepends=('inkscape: use the bundled Peter Wiegel font collection')
_baseurl="https://www.peter-wiegel.de/Fonts"

